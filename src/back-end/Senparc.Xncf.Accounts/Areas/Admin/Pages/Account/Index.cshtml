@page
@model Senparc.Xncf.Accounts.Areas.Account.Pages.Index
@inject Microsoft.Extensions.Localization.IStringLocalizer<Senparc.Xncf.Accounts.AccountsResource> AC
@{
    ViewData["Title"] = AC["Accounts.Title"];
    Layout = "_Layout_Vue";
}

@section breadcrumbs{
    <el-breadcrumb-item>@AC["Accounts.Module"]</el-breadcrumb-item>
    <el-breadcrumb-item>@AC["Accounts.UserManagement"]</el-breadcrumb-item>
    <el-breadcrumb-item>@AC["Accounts.Home"]</el-breadcrumb-item>
}

<div>
    <el-container>
        <el-header class="module-header">
            <span class="start-title"> <i class="fa fa-dot-circle-o"></i>&nbsp;<span class="module-header-v">@AC["Accounts.Home"]</span></span>
        </el-header>

        <!-- 此处也可以加 SideMenu -->
        @*<el-aside width="200px">
            <el-menu background-color="#304156" default-active="1"
                        text-color="#bfcbd9" active-text-color="#409eff">
                @(await Html.PartialAsync("_SideMenu"))
            </el-menu>
        </el-aside>*@
        <el-main>
            <h3>@Model.XncfRegister.MenuName / @Model.XncfRegister.Name</h3>
            <h4>@Model.XncfRegister.Description</h4>
            <br />
            <i>@AC["Accounts.AutoGenerated"]</i>
        </el-main>
    </el-container>
</div>


@section scripts{
    <script>
        new Vue({
            el: "#app"
        });
    </script>
}
