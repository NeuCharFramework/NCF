@model Senparc.Ncf.AreaBase.Admin.IAdminPageModelBase
@inject Senparc.Areas.Admin.Domain.AdminUserInfoService AdminUserInfoService
@{
    var thisYear = DateTime.Now.Year;
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var webLoginExpireMinutes = Senparc.Areas.Admin.Domain.Models.DatabaseModel.AdminAuthConfig.DefaultAdminWebLoginExpireMinutes;
    var jwtExpireMinutes = Senparc.Areas.Admin.Domain.Models.DatabaseModel.AdminAuthConfig.DefaultBackendJwtExpireMinutes;
    var currentAccountName = !string.IsNullOrWhiteSpace(User?.Identity?.Name)
        ? User.Identity.Name
        : !string.IsNullOrWhiteSpace(Model?.AdminWorkContext?.UserName)
            ? Model.AdminWorkContext.UserName
            : !string.IsNullOrWhiteSpace(Model?.UserName)
                ? Model.UserName
                : "-";
    try
    {
        webLoginExpireMinutes = AdminUserInfoService.GetAdminWebLoginExpireMinutes();
        jwtExpireMinutes = AdminUserInfoService.GetBackendJwtExpireMinutes();
    }
    catch
    {
        // 忽略异常并回退默认值，避免布局渲染被配置异常中断。
    }
}
@inject Microsoft.Extensions.Localization.IStringLocalizer<Senparc.Areas.Admin.AdminResource> AR

<!DOCTYPE html>
<html lang="@currentCulture">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <meta name="description" content="@ViewData["Title"]" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <link rel="shortcut icon" href="~/favicon.ico" type="image/x-icon">
    <!-- 引入样式 -->
    <link href="~/lib/element-ui_2.13.2/element.css" rel="stylesheet" />
    <link href="~/css/Admin/Shared/layout.css" rel="stylesheet" />
    <link href="~/lib/font-awesome/css/font-awesome.min.css" rel="stylesheet">
    @RenderSection("HeaderContent", false)
    @RenderSection("Style", false)
</head>
<body>
    <div id="app" v-cloak>
        <div class="app-wrapper">
            <el-container>
                @*菜单栏*@
                <el-aside :style="{'width':Store.state.navMenu.isCollapse?'64px':''}" class="el-aside-index">
                    <div :class="[Store.state.navMenu.isCollapse?'head-log2':'head-log']">
                        <a href="/Admin/Index">
                            <img src="~/images/Admin/base/head/logo_230x55.png" alt="Alternate Text" />
                        </a>
                    </div>
                    <el-scrollbar wrap-class="scrollbar-wrapper" style="height:calc(100vh - 80px);">
                        <el-menu :default-active="Store.state.navMenu.activeMenu"
                                 :collapse="Store.state.navMenu.isCollapse"
                                 :background-color="Store.state.navMenu.variables.menuBg"
                                 :text-color="Store.state.navMenu.variables.menuText"
                                 :active-text-color="Store.state.navMenu.variables.menuActiveText"
                                 :unique-opened="false"
                                 :collapse-transition="false"
                                 @@select="menuSelect"
                                 mode="vertical">
                            <sidebar-item v-for="(items,index) in Store.state.navMenu.navMenuList" :key="index" :item="items"></sidebar-item>
                        </el-menu>
                    </el-scrollbar>
                </el-aside>
                <el-container>
                    <el-header>
                        <div class="header-menu">
                            @*切换菜单栏*@
                            <i class="fa fa-indent" aria-hidden="true" @@click="toggleSideBar"></i>
                        </div>
                        @*面包屑*@
                        <div class="header-breadcrumb">
                            <el-breadcrumb separator="/">
                                <el-breadcrumb-item><a href="/Admin/Index">@AR["Admin.Nav.Home"]</a></el-breadcrumb-item>
                                @RenderSection("breadcrumbs", false)
                            </el-breadcrumb>
                        </div>
                        <div class="header-language">
                            <label for="ncf-lang" class="header-language-label">@AR["Admin.Language.SelectLanguage"]</label>
                            <select id="ncf-lang" class="header-language-select" onchange="ncfSwitchLanguage(this.value)">
                                <option value="zh-CN" selected="@(currentCulture == "zh-CN" ? "selected" : null)">简体中文</option>
                                <option value="en" selected="@(currentCulture.StartsWith("en") ? "selected" : null)">English</option>
                                <option value="ja" selected="@(currentCulture.StartsWith("ja") ? "selected" : null)">日本語</option>
                                <option value="fr" selected="@(currentCulture.StartsWith("fr") ? "selected" : null)">Français</option>
                                <option value="es" selected="@(currentCulture.StartsWith("es") ? "selected" : null)">Español</option>
                                <option value="ru" selected="@(currentCulture.StartsWith("ru") ? "selected" : null)">Русский</option>
                            </select>
                        </div>
                        <div class="header-account">
                            <el-dropdown trigger="click">
                                <span class="el-dropdown-link">
                                    我的账号<i class="el-icon-arrow-down el-icon--right"></i>
                                </span>
                                <el-dropdown-menu slot="dropdown" class="header-account-dropdown">
                                    <el-dropdown-item disabled>当前账号：@currentAccountName</el-dropdown-item>
                                    <el-dropdown-item divided>
                                        <a class="header-account-action" asp-page="/Login" asp-page-handler="Logout">@AR["Admin.Logout.Title"]</a>
                                    </el-dropdown-item>
                                </el-dropdown-menu>
                            </el-dropdown>
                        </div>
                    </el-header>
                    <el-main>
                        <div class="ifram-wrapper">
                            @*<iframe :src="pageSrc"></iframe>*@
                            @RenderBody()
                        </div>
                    </el-main>
                    <el-footer class="footer">
                        Powered by <a href="https://www.ncf.pub" target="_blank">NeuCharFramework</a> © 2010-@thisYear <a href="https://www.senparc.com" target="_blank">盛派网络</a>
                    </el-footer>
                </el-container>
            </el-container>
        </div>
    </div>
    <!--lib-->
    <script src="~/lib/vue/vue.js"></script>
    <script src="~/lib/element-ui_2.13.2/element.js"></script>
    <script src="~/lib/axios/axios.min.js"></script>
    <script src="~/lib/vuex.js"></script>
    <!--js-->
    <script src="~/js/Admin/store.js"></script>
    <script src="~/js/Admin/axios.js"></script>
    <script src="~/js/Admin/global.js"></script>
    <!--菜单栏-->
    <script src="~/js/Admin/navMenu.js"></script>
    <script src="~/js/Admin/vuePermission.js"></script>
    <script src="~/js/Admin/Pages/Components/Components.js"></script>
    <script>
        function ncfSwitchLanguage(culture) {
            var returnUrl = window.location.pathname + window.location.search;
            window.location.href = '/api/Language/Set?culture=' + encodeURIComponent(culture) + '&returnUrl=' + encodeURIComponent(returnUrl);
        }
    </script>
    <!--页面js-->
    @*<script src="~/js/Admin/Pages/Index/Index.js"></script>*@
    @RenderSection("scripts", false)
    <script>
        window.NCF_SESSION_CONFIG = {
            webLoginExpireMinutes: @webLoginExpireMinutes,
            jwtExpireMinutes: @jwtExpireMinutes,
            remindBeforeMinutes: 5
        };
        window.NCF_SESSION_I18N = {
            title: '登录即将过期',
            message: '检测到当前登录会话即将过期，您可以保持登录或立即退出。',
            keepLogin: '保持登录',
            logoutNow: '立即退出登录',
            keepLoginSuccess: '已保持登录，会话已续期。'
        };
        if (typeof window.ncfStartSessionMonitor === 'function') {
            window.ncfStartSessionMonitor();
        }
    </script>
    @Html.AntiForgeryToken()
</body>
</html>
