@page
@model Senparc.Areas.Admin.Pages.AdminChat.ChatModel
@{
    ViewData["Title"] = "AI 智能助手";
    Layout = "_Layout_Vue";
}

@section Style {
    <link rel="stylesheet" href="~/css/Admin/Pages/AdminChat/ChatLauncher.css" />
    <link rel="stylesheet" href="~/css/Admin/Pages/AdminChat/Chat.css" />
}

@section breadcrumbs {
    <el-breadcrumb-item>AI 助手</el-breadcrumb-item>
    <el-breadcrumb-item>对话</el-breadcrumb-item>
}

<div class="admin-chat-container">
    <el-container class="chat-main-container">
        <!-- 左侧会话历史 -->
        <el-aside width="280px" class="chat-sidebar">
            <div class="sidebar-header">
                <h3 class="sidebar-title">
                    <i class="fa fa-comments"></i> 对话历史
                </h3>
                <el-button 
                    type="primary" 
                    size="small" 
                    icon="el-icon-plus" 
                    @@click="createNewSession">
                    新对话
                </el-button>
            </div>
            
            <div class="session-list" v-loading="loadingSessions">
                <div 
                    v-for="session in sessionList" 
                    :key="session.id"
                    :class="['session-item', { 'active': currentSessionId === session.id }]"
                    @@click="switchSession(session.id)">
                    <div class="session-info">
                        <div class="session-title">{{ session.title }}</div>
                        <div class="session-time">{{ formatTime(session.lastMessageTime) }}</div>
                    </div>
                    <el-dropdown trigger="click" @@command="handleSessionCommand">
                        <span class="session-actions" @@click.stop>
                            <i class="el-icon-more"></i>
                        </span>
                        <el-dropdown-menu slot="dropdown">
                            <el-dropdown-item :command="{action: 'delete', id: session.id}">
                                <i class="fa fa-trash"></i> 删除
                            </el-dropdown-item>
                        </el-dropdown-menu>
                    </el-dropdown>
                </div>
                
                <div v-if="sessionList.length === 0 && !loadingSessions" class="empty-sessions">
                    <i class="fa fa-comments-o"></i>
                    <p>暂无对话历史</p>
                </div>
            </div>
        </el-aside>

        <!-- 右侧对话窗口 -->
        <el-main class="chat-content">
            <div class="chat-header" v-if="currentSessionId">
                <div class="chat-header-info">
                    <div class="chat-header-top">
                        <h3 class="chat-title">
                            <i class="fa fa-magic"></i> {{ currentSessionTitle || 'AI 智能助手' }}
                        </h3>
                        <div class="chat-header-actions">
                            <el-select
                                v-model="currentSessionAiModelId"
                                size="mini"
                                class="chat-ai-model-select"
                                :loading="loadingAiModelOptions"
                                @@change="handleCurrentSessionAiModelChange"
                                placeholder="选择 AI 算力">
                                <el-option
                                    v-for="item in aiModelOptions"
                                    :key="item.id"
                                    :label="item.name"
                                    :value="item.id">
                                    <div style="display:flex;justify-content:space-between;gap:12px;align-items:center;">
                                        <span>{{ item.name }}</span>
                                        <span style="color:#999;font-size:12px;">{{ item.description }}</span>
                                    </div>
                                </el-option>
                            </el-select>
                            <el-button
                                size="mini"
                                :type="isManageMode ? 'default' : 'primary'"
                                @@click="toggleManageMode">
                                {{ isManageMode ? '完成' : '管理' }}
                            </el-button>
                        </div>
                    </div>
                    <div class="chat-modules" v-if="currentSessionModules.length > 0">
                        <el-popover
                            v-for="module in currentSessionModules"
                            :key="module.id"
                            placement="bottom-start"
                            width="420"
                            trigger="hover"
                            popper-class="chat-module-detail-popover">
                            <div class="chat-module-detail-wrapper">
                                <div class="module-selector-preview-title">
                                    <i :class="[resolveModuleDetail(module).icon, 'selector-module-icon']"></i>
                                    <span>{{ resolveModuleDetail(module).name }}</span>
                                    <span class="selector-module-version" v-if="resolveModuleDetail(module).version">v{{ resolveModuleDetail(module).version }}</span>
                                </div>
                                <div class="module-selector-preview-subtitle">{{ resolveModuleDetail(module).description }}</div>

                                <div class="module-selector-preview-body">
                                    <div class="module-selector-preview-section" v-if="resolveModuleDetail(module).menus && resolveModuleDetail(module).menus.length > 0">
                                        <div class="module-selector-preview-section-title">菜单层级</div>
                                        <el-tree
                                            :data="resolveModuleDetail(module).menus"
                                            node-key="id"
                                            :props="{ label: 'name', children: 'children' }"
                                            default-expand-all
                                            class="module-selector-menu-tree">
                                            <span class="custom-tree-node" slot-scope="{ data }">
                                                <a :href="data.url">{{ data.name }}</a>
                                            </span>
                                        </el-tree>
                                    </div>

                                    <div class="module-selector-preview-section" v-if="resolveModuleDetail(module).functions && resolveModuleDetail(module).functions.length > 0">
                                        <div class="module-selector-preview-section-title">Functions</div>
                                        <div class="module-selector-functions-list">
                                            <div v-for="func in resolveModuleDetail(module).functions" :key="func.name" class="module-selector-function-item">
                                                <div class="module-selector-function-name">{{ func.name }}</div>
                                                <div class="module-selector-function-description">{{ func.description }}</div>
                                            </div>
                                        </div>
                                    </div>

                                    <div
                                        class="module-selector-preview-empty"
                                        v-if="(!resolveModuleDetail(module).menus || resolveModuleDetail(module).menus.length === 0) && (!resolveModuleDetail(module).functions || resolveModuleDetail(module).functions.length === 0)">
                                        当前模块无可预览详情
                                    </div>
                                </div>
                            </div>

                            <el-tag
                                slot="reference"
                                size="mini"
                                type="info"
                                :title="module.moduleDescription || module.xncfModuleUid"
                                class="chat-module-tag-detail">
                                <i class="fa fa-cube"></i>
                                {{ module.displayName || module.menuName || module.moduleName || module.xncfModuleUid }}
                                <span v-if="module.moduleVersion"> v{{ module.moduleVersion }}</span>
                            </el-tag>
                        </el-popover>
                    </div>
                </div>
            </div>

            <div class="messages-container" ref="messagesContainer" v-loading="loadingMessages" v-if="currentSessionId">
                <div class="message-manage-toolbar" v-if="isManageMode">
                    <el-checkbox
                        :value="messageList.length > 0 && selectedMessageIds.length === messageList.length"
                        :indeterminate="selectedMessageIds.length > 0 && selectedMessageIds.length < messageList.length"
                        @@change="toggleSelectAllMessages">
                        全选
                    </el-checkbox>
                    <span class="message-manage-count">已选 {{ selectedMessageIds.length }} 条</span>
                    <el-button size="mini" @@click="copySelectedMessages" :disabled="selectedMessageIds.length === 0">复制</el-button>
                    <el-button size="mini" @@click="clearMessageSelection" :disabled="selectedMessageIds.length === 0">清空选择</el-button>
                    <el-button size="mini" type="danger" @@click="deleteSelectedMessages" :disabled="selectedMessageIds.length === 0">删除</el-button>
                </div>

                <div 
                    v-for="message in messageList" 
                    :key="message.id"
                    :class="['message-item', `message-${getRoleTypeClass(message.roleType)}`, { 'is-selected': isManageMode && isMessageSelected(message.id) }]">
                    <div class="message-select" v-if="isManageMode">
                        <el-checkbox
                            :value="isMessageSelected(message.id)"
                            @@change="() => toggleMessageSelection(message.id)"
                            @@click.native.stop>
                        </el-checkbox>
                    </div>
                    <div class="message-avatar">
                        <i :class="getMessageIcon(message.roleType)"></i>
                    </div>
                    <div class="message-content">
                        <div class="message-meta">
                            <span class="message-role">{{ getRoleTypeName(message.roleType) }}</span>
                            <span class="message-time">{{ formatTime(message.addTime) }}</span>
                        </div>
                        <div class="message-text" v-html="formatMessageContent(message.content)"></div>
                        <div class="message-actions" v-if="message.roleType === 1 && !isManageMode">
                            <el-button 
                                type="text" 
                                size="mini"
                                :class="{ 'active': message.userFeedback === 1 }"
                                @@click="setFeedback(message.id, 1)">
                                <i class="fa fa-thumbs-up"></i>
                            </el-button>
                            <el-button 
                                type="text" 
                                size="mini"
                                :class="{ 'active': message.userFeedback === 2 }"
                                @@click="setFeedback(message.id, 2)">
                                <i class="fa fa-thumbs-down"></i>
                            </el-button>
                        </div>
                    </div>
                </div>

                <div v-if="messageList.length === 0 && !loadingMessages" class="empty-messages">
                    <i class="fa fa-comment-o"></i>
                    <p>开始您的对话吧</p>
                </div>

                <div v-if="isAIResponding" class="message-item message-assistant ai-thinking">
                    <div class="message-avatar">
                        <i class="fa fa-robot"></i>
                    </div>
                    <div class="message-content">
                        <div class="message-meta">
                            <span class="message-role">AI 助手</span>
                        </div>
                        <div class="message-text">
                            <span class="typing-indicator">
                                <span></span><span></span><span></span>
                            </span>
                            正在思考中...
                        </div>
                    </div>
                </div>
            </div>

            <div class="input-container" v-if="currentSessionId">
                <el-input
                    type="textarea"
                    v-model="inputMessage"
                    placeholder="输入您的问题..."
                    :rows="3"
                    :disabled="!currentSessionId || isSending"
                    @@keydown.native="handleChatInputKeydown"
                    class="message-input">
                </el-input>
                <div class="input-actions">
                    <span class="input-tip">
                        <i class="fa fa-info-circle"></i> Ctrl + Enter 或 Cmd + Enter 发送
                    </span>
                    <el-button 
                        type="primary" 
                        icon="el-icon-s-promotion"
                        :loading="isSending"
                        :disabled="!currentSessionId || !inputMessage || inputMessage.trim().length === 0"
                        @@click="sendMessage">
                        发送
                    </el-button>
                </div>
            </div>

            <div class="chat-empty-launcher" v-else>
                <el-card class="box-card chat-entrance-card">
                    <div class="chat-entrance-container">
                        <div class="chat-entrance-header">
                            <div class="chat-entrance-icon">
                                <i class="fa fa-comments"></i>
                            </div>
                            <div class="chat-entrance-content">
                                <h3 class="chat-entrance-title">
                                    <i class="fa fa-magic"></i> AI 智能助手
                                </h3>
                                <p class="chat-entrance-subtitle">输入问题并选择引用模块，开始新的对话会话</p>
                            </div>
                        </div>

                        <div class="chat-entrance-input-wrapper">
                            <div class="chat-module-picker" style="margin-bottom:16px;">
                                <div class="chat-module-picker-header">
                                    <span class="chat-module-picker-title">AI 算力</span>
                                </div>
                                <el-select
                                    v-model="launcherAiModelId"
                                    class="chat-ai-model-select"
                                    :loading="loadingAiModelOptions"
                                    placeholder="选择 AI 算力"
                                    style="width:100%;">
                                    <el-option
                                        v-for="item in aiModelOptions"
                                        :key="`launcher-${item.id}`"
                                        :label="item.name"
                                        :value="item.id">
                                        <div style="display:flex;justify-content:space-between;gap:12px;align-items:center;">
                                            <span>{{ item.name }}</span>
                                            <span style="color:#999;font-size:12px;">{{ item.description }}</span>
                                        </div>
                                    </el-option>
                                </el-select>
                            </div>

                            <el-input
                                type="textarea"
                                v-model="chatInputText"
                                placeholder="输入您的问题，例如：如何配置系统参数？&#10;&#10;提示：按 Ctrl+Enter 或 Cmd+Enter 发送消息"
                                :rows="4"
                                :autosize="{ minRows: 4, maxRows: 8 }"
                                @@keydown.native="handleLauncherInputKeydown"
                                class="chat-entrance-input"
                                resize="none">
                            </el-input>
                            <el-button
                                type="primary"
                                size="medium"
                                icon="el-icon-s-promotion"
                                @@click="startChatSession"
                                :disabled="!chatInputText || chatInputText.trim().length === 0"
                                :loading="isCreatingSession"
                                class="chat-send-button">
                                开始对话
                            </el-button>
                        </div>

                        <div class="chat-module-picker">
                            <div class="chat-module-picker-header">
                                <span class="chat-module-picker-title">引用模块（可选）</span>
                                <div class="chat-module-picker-actions">
                                    <el-button size="mini" type="primary" icon="el-icon-plus" @@click="openModuleSelector">添加引用模块</el-button>
                                    <el-button size="mini" @@click="clearSelectedModules" v-if="selectedModules.length > 0">清空</el-button>
                                </div>
                            </div>

                            <div v-if="selectedModules.length > 0" class="chat-module-selected-list">
                                <el-tag
                                    v-for="module in selectedModules"
                                    :key="module.uid"
                                    closable
                                    @@close="removeModule(module.uid)"
                                    type="info"
                                    class="module-tag">
                                    <i :class="module.icon"></i> {{module.name}}
                                </el-tag>
                            </div>
                            <div v-else class="chat-module-selected-empty">点击“添加引用模块”可选择多个模块作为上下文</div>
                        </div>

                        @await Html.PartialAsync("~/Areas/Admin/Pages/Shared/_ChatModuleSelectorDialog.cshtml")
                    </div>
                </el-card>
            </div>
        </el-main>
    </el-container>
</div>

@section scripts {
    <script src="~/js/Admin/Pages/AdminChat/ChatLauncherMixin.js"></script>
    <script>
        window.INITIAL_DATA = {
            sessionId: @(Model.SessionId),
            initialMessage: '@Html.Raw(Model.InitialMessage?.Replace("'", "\\'").Replace("\n", "\\n"))',
            currentUserId: @(Model.CurrentUserId),
            moduleUids: '@Html.Raw(Model.ModuleUids)'
        };
    </script>
    <script src="~/js/Admin/Pages/AdminChat/Chat.js"></script>
}
